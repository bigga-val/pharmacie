{% extends 'components/layout/default.html.twig' %}

{% block content %}
<div class="panel">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-lg font-semibold text-gray-800 dark:text-white">Nouvel employé</h2>
            <p class="text-sm text-gray-400">Enregistrer un nouveau membre du personnel</p>
        </div>
        <a href="{{ path('app_employe_index') }}" class="btn btn-outline-secondary btn-sm">
            ← Retour à la liste
        </a>
    </div>
</div>

<div class="panel mt-4 max-w-2xl">
    {{ form_start(form) }}
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

        <div class="sm:col-span-2 space-y-1">
            <label class="block text-sm font-medium text-gray-600 dark:text-gray-300">Nom complet</label>
            {{ form_widget(form.nomcomplet, {'attr': {'class': 'form-input', 'placeholder': 'Prénom et nom'}}) }}
        </div>

        <div class="space-y-1">
            <label class="block text-sm font-medium text-gray-600 dark:text-gray-300">Matricule</label>
            {{ form_widget(form.matricule, {'attr': {'class': 'form-input', 'placeholder': 'Ex: EMP-001'}}) }}
        </div>

        <div class="space-y-1">
            <label class="block text-sm font-medium text-gray-600 dark:text-gray-300">Titre / Poste</label>
            {{ form_widget(form.titre, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Pharmacien'}}) }}
        </div>

        <div class="space-y-1">
            <label class="block text-sm font-medium text-gray-600 dark:text-gray-300">Catégorie</label>
            {{ form_widget(form.categorie, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Cadre, Agent…'}}) }}
        </div>

        <div class="space-y-1">
            <label class="block text-sm font-medium text-gray-600 dark:text-gray-300">Date d'embauche</label>
            {{ form_widget(form.dateembauche, {'attr': {'class': 'form-input'}}) }}
        </div>

        <div class="space-y-1">
            <label class="block text-sm font-medium text-gray-600 dark:text-gray-300">Salaire journalier</label>
            {{ form_widget(form.salaireJournalier, {'attr': {'class': 'form-input', 'placeholder': '0.00'}}) }}
        </div>

    </div>

    <div class="flex items-center gap-3 mt-7 pt-5 border-t border-gray-100 dark:border-[#1b2e4b]">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="{{ path('app_employe_index') }}" class="btn btn-outline-secondary">Annuler</a>
    </div>
    {{ form_end(form) }}
</div>
{% endblock %}
