{% extends 'components/layout/default.html.twig' %}

{% block content %}
<div class="panel">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-lg font-semibold text-gray-800 dark:text-white">Employés</h2>
            <p class="text-sm text-gray-400">Liste du personnel enregistré</p>
        </div>
        <a href="{{ path('app_employe_new') }}" class="btn btn-primary gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            Nouvel employé
        </a>
    </div>
</div>

<div class="panel mt-4">
    <div class="table-responsive">
        <table class="table-hover">
            <thead>
                <tr>
                    <th>Employé</th>
                    <th>Matricule</th>
                    <th>Titre</th>
                    <th>Catégorie</th>
                    <th>Date d'embauche</th>
                    <th>Salaire / jour</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for employe in employes %}
                <tr>
                    <td>
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-primary/15 flex items-center justify-center shrink-0">
                                <span class="text-xs font-bold text-primary">{{ employe.nomcomplet|slice(0,1)|upper }}</span>
                            </div>
                            <span class="font-medium text-gray-800 dark:text-white">{{ employe.nomcomplet }}</span>
                        </div>
                    </td>
                    <td><span class="font-mono text-sm text-gray-500">{{ employe.matricule }}</span></td>
                    <td>{{ employe.titre }}</td>
                    <td>
                        {% if employe.categorie %}
                            <span class="badge bg-info/15 text-info text-xs px-2 py-0.5 rounded-full font-medium">{{ employe.categorie }}</span>
                        {% else %}—{% endif %}
                    </td>
                    <td class="text-gray-500 text-sm">{{ employe.dateembauche ? employe.dateembauche|date('d/m/Y') : '—' }}</td>
                    <td class="font-semibold">{{ (employe.salaireJournalier ?? 0)|number_format(2) }}</td>
                    <td>
                        <div class="flex items-center justify-center gap-2">
                            <a href="{{ path('app_employe_payer', {'id': employe.id}) }}"
                               class="btn btn-sm btn-success">Payer</a>
                            <a href="{{ path('app_employe_edit', {'id': employe.id}) }}"
                               class="btn btn-sm btn-outline-primary">Modifier</a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center py-10 text-gray-400">
                        <svg class="mx-auto mb-2 w-10 h-10 opacity-30" viewBox="0 0 24 24" fill="none">
                            <circle cx="9" cy="6" r="4" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M2 20C2 16.134 5.582 13 10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M19 17V21M21 19H17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        Aucun employé enregistré
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
