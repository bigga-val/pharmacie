{% extends 'components/layout/default.html.twig' %}
{% block content %}
<style>
    @media print {
        body * { visibility: hidden !important; }
        #printable, #printable * { visibility: visible !important; }
        #printable { position: absolute; left: 0; top: 0; width: 100%; }
        .no-print { display: none !important; }
    }
</style>

<input type="hidden" value="{{ vente.id }}" id="venteID">

{# ── En-tête facture ── #}
<div class="panel mb-4 no-print">
    <div class="flex flex-wrap justify-between items-center gap-3">

        {# Infos facture #}
        <div>
            <div class="text-xs text-gray-400 uppercase font-semibold">Facture</div>
            <div class="text-2xl font-bold text-primary">{{ vente.numeroVente }}</div>
            <div class="text-sm text-gray-500 mt-1">
                {{ vente.venteDate ? vente.venteDate|date('d/m/Y') : '' }}
                &bull; {{ vente.createdBy }}
            </div>
        </div>

        {# Statut #}
        <div class="text-center">
            {% if vente.statusVente == 'paid' %}
                <span class="inline-block bg-success text-white text-sm font-semibold px-4 py-2 rounded-full">Payée</span>
            {% elseif vente.statusVente == 'progress' %}
                <span class="inline-block bg-primary text-white text-sm font-semibold px-4 py-2 rounded-full">En cours</span>
            {% else %}
                <span class="inline-block bg-danger text-white text-sm font-semibold px-4 py-2 rounded-full">Annulée</span>
            {% endif %}
        </div>

        {# Actions #}
        <div class="flex flex-wrap gap-2">
            <a target="_blank" href="{{ path('app_generate_pdf', {'id': vente.id}) }}" class="btn btn-secondary btn-sm">
                PDF / Imprimer
            </a>

            {% if vente.statusVente == 'progress' %}
                <a id="btnConfirm" href="{{ path('app_vente_confirm', {'id': vente.id}) }}" class="btn btn-success btn-sm">
                    Confirmer le paiement
                </a>
                <a id="btnCancel" href="{{ path('app_vente_cancel', {'id': vente.id}) }}" class="btn btn-outline-danger btn-sm">
                    Annuler
                </a>
            {% elseif vente.statusVente == 'paid' and is_granted('ROLE_ADMIN') %}
                <a id="btnCancel" href="{{ path('app_vente_cancel', {'id': vente.id}) }}" class="btn btn-outline-danger btn-sm">
                    Annuler (admin)
                </a>
            {% elseif vente.statusVente == 'canceled' and is_granted('ROLE_ADMIN') %}
                <a id="btnConfirm" href="{{ path('app_vente_confirm', {'id': vente.id}) }}" class="btn btn-success btn-sm">
                    Rétablir (admin)
                </a>
            {% endif %}
        </div>
    </div>
</div>

{# ── Tableau des lignes ── #}
<div class="panel" id="printable">
    <div class="mb-3">
        <h2 class="font-semibold text-lg">Détail des produits</h2>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>Produit</th>
                <th class="text-right">Qté</th>
                <th class="text-right">Prix unitaire</th>
                <th class="text-right">Total (FC)</th>
                <th class="text-right">Total (USD)</th>
                <th class="no-print"></th>
            </tr>
        </thead>
        <tbody class="tbody">
            {% set counter = 0 %}
            {% set grandTotalFC  = 0 %}
            {% set grandTotalUSD = 0 %}
            {% for produit in produitsVendu %}
                {% set counter = counter + 1 %}
                {% set lignFC  = produit.qty * produit.prixUnitaire %}
                {% set lignUSD = produit.taux > 0 ? lignFC / produit.taux : 0 %}
                {% set grandTotalFC  = grandTotalFC  + lignFC %}
                {% set grandTotalUSD = grandTotalUSD + lignUSD %}
                <tr>
                    <td class="text-gray-400">{{ counter }}</td>
                    <td class="font-medium">{{ produit.produit.designation }}</td>
                    <td class="text-right">{{ produit.qty }}</td>
                    <td class="text-right">{{ produit.prixUnitaire|number_format(0, ',', ' ') }} FC</td>
                    <td class="text-right font-semibold">{{ lignFC|number_format(0, ',', ' ') }} FC</td>
                    <td class="text-right text-gray-400">{{ lignUSD|number_format(2, ',', ' ') }} $</td>
                    <td class="text-right no-print">
                        {% if vente.statusVente == 'progress' or (vente.statusVente == 'paid' and is_granted('ROLE_ADMIN')) %}
                            <button id="{{ produit.id }}" class="remove-old-row btn btn-danger btn-sm">Retirer</button>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center text-gray-400 py-4">Aucun produit sur cette facture.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {# ── Total des lignes enregistrées ── #}
    <div class="flex justify-end mt-2 border-t pt-3 gap-8">
        <div class="text-right">
            <div class="text-xs text-gray-400 uppercase font-semibold mb-1">Total (CDF)</div>
            <div class="text-2xl font-bold text-primary">
                {{ grandTotalFC|number_format(0, ',', ' ') }} FC
            </div>
        </div>
        <div class="text-right">
            <div class="text-xs text-gray-400 uppercase font-semibold mb-1">Total (USD)</div>
            <div class="text-2xl font-bold text-dark">
                {{ grandTotalUSD|number_format(2, ',', ' ') }} $
            </div>
        </div>
    </div>

    {# ── Zone d'ajout de nouvelles lignes ── #}
    {% if vente.statusVente == 'progress' or (vente.statusVente == 'paid' and is_granted('ROLE_ADMIN')) %}
    <div class="mt-6 border-t pt-4 no-print">
        <div class="flex justify-between items-center mb-3">
            <h3 class="font-semibold text-gray-600">Ajouter des produits</h3>
            <div class="flex gap-2">
                <button id="add-row" class="btn btn-primary btn-sm">+ Ajouter une ligne</button>
                <button id="saveNewLines" class="btn btn-success btn-sm">Enregistrer</button>
            </div>
        </div>

        <span id="errorSpan" class="text-danger text-sm"></span>

        <table class="table mt-2" id="newLinesTable" style="display:none">
            <thead>
                <tr>
                    <th>Produit</th>
                    <th>Stock dispo</th>
                    <th>Quantité</th>
                    <th>Prix unitaire (FC)</th>
                    <th>Total (FC)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="newLinesTbody"></tbody>
        </table>

        <div class="flex justify-end mt-2" id="newLinesTotal" style="display:none">
            <div class="text-sm text-gray-500">
                Sous-total nouvelles lignes : <span class="font-semibold" id="subtotal">0</span> FC
            </div>
        </div>
    </div>
    {% endif %}
</div>

<script src="{{ asset('assets/js/jquery.min.js') }}"></script>
<script>
$(document).ready(function () {

    // ── Confirmations ───────────────────────────────────────────────────────
    const userIsHabilite = {{ (is_granted('ROLE_INFIRMIERE') and not is_granted('ROLE_PHARMACIEN')) ? 'true' : 'false' }};

    $("#btnCancel").on('click', function (e) {
        if (!userIsHabilite && !confirm("Attention : cette action devrait normalement être effectuée par une infirmière ou un personnel habilité.\n\nVoulez-vous continuer quand même ?")) {
            e.preventDefault(); return;
        }
        if (!confirm("Êtes-vous sûr(e) de vouloir annuler cette facture ?")) e.preventDefault();
    });
    $("#btnConfirm").on('click', function (e) {
        if (!userIsHabilite && !confirm("Attention : cette action devrait normalement être effectuée par une infirmière ou un personnel habilité.\n\nVoulez-vous continuer quand même ?")) {
            e.preventDefault(); return;
        }
        if (!confirm("Confirmer le paiement de cette facture ?")) e.preventDefault();
    });

    // ── Supprimer une ligne enregistrée ─────────────────────────────────────
    $('table').on('click', '.remove-old-row', function () {
        if (!confirm("Retirer ce produit de la facture ?")) return;
        const ligneID = $(this).prop('id');
        const $row = $(this).closest('tr');
        $.get('/produit/vendu/jsonDeleteLigneVente', { ligneID }, function () {
            raiseToastr('success', 'Ligne retirée avec succès !');
            location.reload();
        }).fail(function () {
            raiseToastr('error', 'Erreur lors du retrait.');
        });
    });

    // ── Mise à jour du sous-total des nouvelles lignes ───────────────────────
    function setTotal() {
        let subtotal = 0;
        $('#newLinesTbody .item-total').each(function () {
            subtotal += parseFloat($(this).data('raw')) || 0;
        });
        $('#subtotal').text(subtotal.toLocaleString('fr-FR'));
    }

    // ── Template nouvelle ligne ──────────────────────────────────────────────
    function buildNewRow(counter) {
        const opts = '<option value="-1">Choisir un produit</option>'
            {% for produit in produits %}
            + '<option value="{{ produit.produitID }}">{{ produit.designation }}</option>'
            {% endfor %};

        return $('<tr class="prod_Line">'
            + '<td><select class="form-input item-product" name="select-' + counter + '">' + opts + '</select></td>'
            + '<td><span class="item-dispo text-sm text-gray-500">—</span> <span class="item-unit text-xs text-gray-400"></span></td>'
            + '<td><input type="number" min="1" placeholder="Qté" class="form-input item-quantity" style="width:80px"></td>'
            + '<td><input type="number" class="form-input item-prix" readonly style="width:120px"></td>'
            + '<td><span class="item-total font-semibold" data-raw="0">0</span></td>'
            + '<td><button type="button" class="remove-row btn btn-danger btn-sm">✕</button></td>'
            + '</tr>');
    }

    // ── Ajouter une ligne ────────────────────────────────────────────────────
    let counter = 0;
    $('#add-row').on('click', function () {
        counter++;
        const $row = buildNewRow(counter);
        $('#newLinesTbody').append($row);
        $('#newLinesTable, #newLinesTotal').show();
        bindRowEvents($row);
    });

    // ── Supprimer une nouvelle ligne ─────────────────────────────────────────
    $('#newLinesTbody').on('click', '.remove-row', function () {
        $(this).closest('tr').remove();
        if ($('#newLinesTbody tr').length === 0) {
            $('#newLinesTable, #newLinesTotal').hide();
        }
        setTotal();
    });

    // ── Events sur une ligne (produit + quantité) ────────────────────────────
    function bindRowEvents($row) {
        const $select   = $row.find('.item-product');
        const $qty      = $row.find('.item-quantity');
        const $prix     = $row.find('.item-prix');
        const $dispo    = $row.find('.item-dispo');
        const $unit     = $row.find('.item-unit');
        const $total    = $row.find('.item-total');

        $select.on('change', function () {
            const productID = $(this).val();
            if (productID == -1) return;

            $.get('/vente/jsonGetProduct2', { productID }, function (response) {
                const data = response['data'][0];
                if (!data) return;

                const te = parseFloat(data['totalEntree'])  || 0;
                const ts = parseFloat(data['totalSortie'])  || 0;
                const tr = parseFloat(data['totalReserve']) || 0;
                const stockDispo = Math.max(te - ts - tr, 0);

                $dispo.text(stockDispo);
                $unit.text(data['uniteMesure'] ? '(' + data['uniteMesure'] + ')' : '');
                $prix.val(data['prix']);
                $total.text('0').data('raw', 0);
                $qty.val('').attr('max', stockDispo).focus();
                setTotal();
            });
        });

        $qty.on('input', function () {
            const qty       = parseFloat($(this).val()) || 0;
            const prix      = parseFloat($prix.val())   || 0;
            const dispo     = parseFloat($dispo.text())  || 0;
            $('#errorSpan').text('');

            if (qty <= 0) {
                $('#errorSpan').text('La quantité doit être supérieure à 0.');
                $total.text('0').data('raw', 0);
            } else if (qty > dispo) {
                $('#errorSpan').text('Stock insuffisant : ' + dispo + ' disponible(s).');
                $total.text('0').data('raw', 0);
            } else {
                const t = qty * prix;
                $total.text(t.toLocaleString('fr-FR')).data('raw', t);
            }
            setTotal();
        });
    }

    // ── Enregistrer les nouvelles lignes ─────────────────────────────────────
    $('#saveNewLines').on('click', function () {
        const venteID   = $('#venteID').val();
        const requests  = [];
        let hasError    = false;

        $('#newLinesTbody .prod_Line').each(function () {
            const productID = $(this).find('.item-product').val();
            const qty       = $(this).find('.item-quantity').val();

            if (productID == -1 || !qty || parseFloat(qty) <= 0) return;

            requests.push($.get('/produit/vendu/jsonSaveLigneVente', {
                venteID, produitID: productID, qty
            }));
        });

        if (requests.length === 0) {
            raiseToastr('warning', 'Aucune ligne valide à enregistrer.');
            return;
        }

        $.when(...requests).done(function () {
            raiseToastr('success', 'Vente enregistrée avec succès !');
            location.reload();
        }).fail(function () {
            raiseToastr('error', 'Erreur lors de l\'enregistrement.');
        });
    });

});
</script>

{% endblock %}
