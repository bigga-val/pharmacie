{% extends 'components/layout/default.html.twig' %}

{% block content %}
<div class="panel">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-lg font-semibold text-gray-800 dark:text-white">Modifier la période</h2>
            <p class="text-sm text-gray-400">{{ paie.label }}</p>
        </div>
        <a href="{{ path('app_paie_index') }}" class="btn btn-outline-secondary btn-sm">← Retour</a>
    </div>
</div>

<div class="panel mt-4 max-w-lg">
    {{ form_start(form) }}
    <div class="space-y-5">

        <div class="space-y-1">
            <label class="block text-sm font-medium text-gray-600 dark:text-gray-300">Libellé</label>
            {{ form_widget(form.label, {'attr': {'class': 'form-input'}}) }}
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1">
                <label class="block text-sm font-medium text-gray-600 dark:text-gray-300">Mois</label>
                {{ form_widget(form.MonthPay, {'attr': {'class': 'form-input', 'min': 1, 'max': 12}}) }}
            </div>
            <div class="space-y-1">
                <label class="block text-sm font-medium text-gray-600 dark:text-gray-300">Année</label>
                {{ form_widget(form.YearPay, {'attr': {'class': 'form-input'}}) }}
            </div>
        </div>

    </div>

    <div class="flex items-center gap-3 mt-7 pt-5 border-t border-gray-100 dark:border-[#1b2e4b]">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="{{ path('app_paie_index') }}" class="btn btn-outline-secondary">Annuler</a>
    </div>
    {{ form_end(form) }}
</div>
{% endblock %}
