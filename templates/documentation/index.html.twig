{% extends 'components/layout/default.html.twig' %}

{% block content %}
<div x-data="{ activeTab: 'intro' }">

    {# Breadcrumb #}
    <ul class="flex space-x-2 rtl:space-x-reverse mb-5">
        <li><a href="{{ path('app_dashboard') }}" class="text-primary hover:underline">Accueil</a></li>
        <li class="before:content-['/'] ltr:before:mr-1 rtl:before:ml-1"><span>Documentation</span></li>
    </ul>

    {# En-tête #}
    <div class="mb-6">
        <h2 class="text-2xl font-bold">Manuel Utilisateur</h2>
        <p class="text-white-dark mt-1">Guide complet d'utilisation de la plateforme · Version 1.0</p>
    </div>

    {# Grille des modules (accès rapide) #}
    <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-6 gap-4 mb-8">

        <button @click="activeTab = 'ventes'"
            class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726] p-4 text-center group hover:border-primary hover:shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)] transition-all"
            :class="activeTab === 'ventes' ? 'border-primary shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)]' : ''">
            <svg class="w-8 h-8 mx-auto text-primary mb-2" viewBox="0 0 24 24" fill="none"><path opacity="0.5" d="M3 10C3 6.22876 3 4.34315 4.17157 3.17157C5.34315 2 7.22876 2 11 2H13C16.7712 2 18.6569 2 19.8284 3.17157C21 4.34315 21 6.22876 21 10V14C21 17.7712 21 19.6569 19.8284 20.8284C18.6569 22 16.7712 22 13 22H11C7.22876 22 5.34315 22 4.17157 20.8284C3 19.6569 3 17.7712 3 14V10Z" fill="currentColor"/><path d="M8 12H16M8 8H16M8 16H13" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
            <p class="text-xs font-semibold">Ventes</p>
        </button>

        <button @click="activeTab = 'produits'"
            class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726] p-4 text-center group hover:border-primary hover:shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)] transition-all"
            :class="activeTab === 'produits' ? 'border-primary shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)]' : ''">
            <svg class="w-8 h-8 mx-auto text-primary mb-2" viewBox="0 0 24 24" fill="none"><path opacity="0.5" fill-rule="evenodd" clip-rule="evenodd" d="M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M12 5.25C12.4142 5.25 12.75 5.58579 12.75 6V6.31673C14.3804 6.60867 15.75 7.83361 15.75 9.5C15.75 9.91421 15.4142 10.25 15 10.25C14.5858 10.25 14.25 9.91421 14.25 9.5C14.25 8.82154 13.6859 8.10339 12.75 7.84748V11.3167C14.3804 11.6087 15.75 12.8336 15.75 14.5C15.75 16.1664 14.3804 17.3913 12.75 17.6833V18C12.75 18.4142 12.4142 18.75 12 18.75C11.5858 18.75 11.25 18.4142 11.25 18V17.6833C9.61957 17.3913 8.25 16.1664 8.25 14.5C8.25 14.0858 8.58579 13.75 9 13.75C9.41421 13.75 9.75 14.0858 9.75 14.5C9.75 15.1785 10.3141 15.8966 11.25 16.1525V12.6833C9.61957 12.3913 8.25 11.1664 8.25 9.5C8.25 7.83361 9.61957 6.60867 11.25 6.31673V6C11.25 5.58579 11.5858 5.25 12 5.25Z" fill="currentColor"/></svg>
            <p class="text-xs font-semibold">Produits</p>
        </button>

        <button @click="activeTab = 'commandes'"
            class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726] p-4 text-center group hover:border-primary hover:shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)] transition-all"
            :class="activeTab === 'commandes' ? 'border-primary shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)]' : ''">
            <svg class="w-8 h-8 mx-auto text-primary mb-2" viewBox="0 0 24 24" fill="none"><path opacity="0.5" d="M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z" fill="currentColor"/><path d="M8 8h8M8 12h8M8 16h5" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
            <p class="text-xs font-semibold">Bon de commande</p>
        </button>

        <button @click="activeTab = 'stock'"
            class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726] p-4 text-center group hover:border-primary hover:shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)] transition-all"
            :class="activeTab === 'stock' ? 'border-primary shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)]' : ''">
            <svg class="w-8 h-8 mx-auto text-primary mb-2" viewBox="0 0 24 24" fill="none"><path opacity="0.5" d="M2 12.2039C2 9.91549 2 8.77128 2.5192 7.82274C3.0384 6.87421 3.98695 6.28551 5.88403 5.10813L7.88403 3.86687C9.88939 2.62229 10.8921 2 12 2C13.1079 2 14.1106 2.62229 16.116 3.86687L18.116 5.10812C20.0131 6.28551 20.9616 6.87421 21.4808 7.82274C22 8.77128 22 9.91549 22 12.2039V13.725C22 17.6258 22 19.5763 20.8284 20.7881C19.6569 22 17.7712 22 14 22H10C6.22876 22 4.34315 22 3.17157 20.7881C2 19.5763 2 17.6258 2 13.725V12.2039Z" fill="currentColor"/><path d="M9 17.25C8.58579 17.25 8.25 17.5858 8.25 18C8.25 18.4142 8.58579 18.75 9 18.75H15C15.4142 18.75 15.75 18.4142 15.75 18C15.75 17.5858 15.4142 17.25 15 17.25H9Z" fill="currentColor"/></svg>
            <p class="text-xs font-semibold">Stock</p>
        </button>

        <button @click="activeTab = 'caisse'"
            class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726] p-4 text-center group hover:border-primary hover:shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)] transition-all"
            :class="activeTab === 'caisse' ? 'border-primary shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)]' : ''">
            <svg class="w-8 h-8 mx-auto text-primary mb-2" viewBox="0 0 24 24" fill="none"><path opacity="0.5" d="M4 18V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path opacity="0.5" d="M20 12H4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M20 6H4M20 18H4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9 6V18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <p class="text-xs font-semibold">Caisse</p>
        </button>

        <button @click="activeTab = 'rh'"
            class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726] p-4 text-center group hover:border-primary hover:shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)] transition-all"
            :class="activeTab === 'rh' ? 'border-primary shadow-[0px_0px_2px_0px_rgba(67,97,238,0.30)]' : ''">
            <svg class="w-8 h-8 mx-auto text-primary mb-2" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="6" r="4" stroke="currentColor" stroke-width="1.5"/><ellipse opacity="0.5" cx="12" cy="17" rx="7" ry="4" stroke="currentColor" stroke-width="1.5"/></svg>
            <p class="text-xs font-semibold">RH & Paie</p>
        </button>

    </div>

    {# Navigation onglets #}
    <div class="border-b border-[#ebedf2] dark:border-[#191e3a] mb-5 overflow-x-auto">
        <ul class="flex flex-nowrap text-center font-semibold text-sm whitespace-nowrap gap-1">
            <li><button @click="activeTab = 'intro'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'intro' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Introduction</button></li>
            <li><button @click="activeTab = 'connexion'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'connexion' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Connexion</button></li>
            <li><button @click="activeTab = 'dashboard'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'dashboard' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Dashboard</button></li>
            <li><button @click="activeTab = 'ventes'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'ventes' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Ventes</button></li>
            <li><button @click="activeTab = 'produits'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'produits' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Produits</button></li>
            <li><button @click="activeTab = 'commandes'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'commandes' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Bon de commande</button></li>
            <li><button @click="activeTab = 'stock'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'stock' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Stock</button></li>
            <li><button @click="activeTab = 'caisse'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'caisse' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Caisse</button></li>
            <li><button @click="activeTab = 'rh'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'rh' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">RH & Paie</button></li>
            <li><button @click="activeTab = 'admin'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'admin' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Administration</button></li>
            <li><button @click="activeTab = 'roles'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'roles' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">Rôles</button></li>
            <li><button @click="activeTab = 'faq'" class="px-4 py-2.5 transition-all border-b-2 -mb-px" :class="activeTab === 'faq' ? 'border-primary text-primary' : 'border-transparent hover:text-primary'">FAQ</button></li>
        </ul>
    </div>

    {# ═══════════════════════════════════════ #}
    {# ONGLET : INTRODUCTION #}
    {# ═══════════════════════════════════════ #}
    <div x-show="activeTab === 'intro'">
        <div class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726] p-6 mb-4">
            <h3 class="text-lg font-bold mb-4">Bienvenue sur Afya</h3>
            <p class="text-white-dark mb-4">
                <strong class="text-black dark:text-white">Afya</strong> est une application de gestion d'entreprise complète.
                Elle couvre l'ensemble des opérations quotidiennes : ventes, stocks, commandes, trésorerie, ressources humaines et administration.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex items-start gap-3 p-4 rounded-md bg-primary/10">
                    <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="text-sm font-semibold text-primary">Ventes & facturation avec export PDF</span>
                </div>
                <div class="flex items-start gap-3 p-4 rounded-md bg-primary/10">
                    <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="text-sm font-semibold text-primary">Bon de commande fournisseur (export PDF)</span>
                </div>
                <div class="flex items-start gap-3 p-4 rounded-md bg-primary/10">
                    <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="text-sm font-semibold text-primary">Approvisionnement & suivi des stocks</span>
                </div>
                <div class="flex items-start gap-3 p-4 rounded-md bg-primary/10">
                    <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="text-sm font-semibold text-primary">Caisse & trésorerie FC / USD</span>
                </div>
                <div class="flex items-start gap-3 p-4 rounded-md bg-primary/10">
                    <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="text-sm font-semibold text-primary">Gestion des employés & de la paie</span>
                </div>
                <div class="flex items-start gap-3 p-4 rounded-md bg-primary/10">
                    <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="text-sm font-semibold text-primary">Taux de change & alertes configurables</span>
                </div>
            </div>
            <div class="mt-5 flex items-center gap-2 p-3 rounded-md bg-info/10 border border-info/20">
                <svg class="w-4 h-4 text-info shrink-0" viewBox="0 0 24 24" fill="none"><path opacity="0.5" d="M12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2Z" fill="currentColor"/><path d="M12 7.75V13M12 16.25V16" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
                <span class="text-sm text-info font-semibold">L'application supporte deux devises : le <strong>Franc Congolais (FC)</strong> et le <strong>Dollar Américain (USD)</strong>.</span>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════ #}
    {# ONGLET : CONNEXION #}
    {# ═══════════════════════════════════════ #}
    <div x-show="activeTab === 'connexion'" x-cloak>
        <div class="space-y-4" x-data="{ active: null }">

            <div class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726]">
                <div class="flex font-semibold p-5 cursor-pointer" :class="{ 'text-primary': active === 1 }" x-on:click="active === 1 ? active = null : active = 1">
                    <span>Se connecter</span>
                    <svg class="w-5 h-5 ltr:ml-auto rtl:mr-auto transition-transform" :class="{ 'rotate-180': active === 1 }" viewBox="0 0 24 24" fill="none"><path d="M19 9L12 15L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div x-cloak x-show="active === 1" x-collapse>
                    <div class="px-5 pb-5 text-white-dark">
                        <ol class="list-decimal list-inside space-y-2 text-sm">
                            <li>Ouvrez l'application dans votre navigateur.</li>
                            <li>Saisissez votre <strong class="text-black dark:text-white">nom d'utilisateur</strong> et votre <strong class="text-black dark:text-white">mot de passe</strong>.</li>
                            <li>Cliquez sur <span class="inline-block bg-primary/10 text-primary text-xs font-bold px-2 py-0.5 rounded">Se connecter</span>.</li>
                        </ol>
                        <div class="mt-3 flex items-center gap-2 p-3 rounded-md bg-warning/10 border border-warning/20 text-sm text-warning">
                            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none"><path opacity="0.5" d="M12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2Z" fill="currentColor"/><path d="M12 7.75V13M12 16.25V16" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
                            Si vous n'avez pas de compte, contactez votre administrateur.
                        </div>
                    </div>
                </div>
            </div>

            <div class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726]">
                <div class="flex font-semibold p-5 cursor-pointer" :class="{ 'text-primary': active === 2 }" x-on:click="active === 2 ? active = null : active = 2">
                    <span>Se déconnecter</span>
                    <svg class="w-5 h-5 ltr:ml-auto rtl:mr-auto transition-transform" :class="{ 'rotate-180': active === 2 }" viewBox="0 0 24 24" fill="none"><path d="M19 9L12 15L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div x-cloak x-show="active === 2" x-collapse>
                    <div class="px-5 pb-5 text-white-dark text-sm">
                        Cliquez sur votre nom ou l'icône de profil en haut à droite, puis sélectionnez <span class="inline-block bg-primary/10 text-primary text-xs font-bold px-2 py-0.5 rounded">Se déconnecter</span>.
                    </div>
                </div>
            </div>

            <div class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726]">
                <div class="flex font-semibold p-5 cursor-pointer" :class="{ 'text-primary': active === 3 }" x-on:click="active === 3 ? active = null : active = 3">
                    <span>Première connexion</span>
                    <svg class="w-5 h-5 ltr:ml-auto rtl:mr-auto transition-transform" :class="{ 'rotate-180': active === 3 }" viewBox="0 0 24 24" fill="none"><path d="M19 9L12 15L5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div x-cloak x-show="active === 3" x-collapse>
                    <div class="px-5 pb-5 text-white-dark text-sm">
                        Lors de votre première connexion, l'application peut vous demander de configurer votre session. Suivez les instructions affichées à l'écran.
                    </div>
                </div>
            </div>

        </div>
    </div>

    {# ═══════════════════════════════════════ #}
    {# ONGLET : DASHBOARD #}
    {# ═══════════════════════════════════════ #}
    <div x-show="activeTab === 'dashboard'" x-cloak>
        <div class="border border-[#ebedf2] dark:border-[#191e3a] rounded-md bg-white dark:bg-[#0e1726] p-6 mb-4">
            <div class="flex items-center gap-2 mb-4">
                <h3 class="text-base font-bold">Tableau de bord</h3>
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-success/10 text-success border border-success/20">Tous les rôles</span>
            </div>
            <p class="text-white-dark text-sm mb-5">Page d'accueil accessible à tous les utilisateurs connectés. Le contenu affiché varie selon le rôle : l'infirmière voit les KPI de ventes et les graphiques ; le pharmacien voit en plus le journal d'audit ; l'admin voit tout (caisse, masse salariale, employés, audit).</p>

            <h4 class="font-bold text-sm mb-3">Indicateurs clés (KPI)</h4>
            <div class="table-responsive mb-5">
                <table class="table-hover">
                    <thead><tr><th>Indicateur</th><th>Description</th></tr></thead>
                    <tbody>
                        <tr><td class="font-semibold">CA Hier</td><td class="text-white-dark">Chiffre d'affaires réalisé la veille, avec variation en %</td></tr>
                        <tr><td class="font-semibold">CA du mois</td><td class="text-white-dark">Chiffre d'affaires cumulé du mois en cours</td></tr>
                        <tr><td class="font-semibold">Transactions du mois</td><td class="text-white-dark">Nombre de ventes effectuées ce mois</td></tr>
                        <tr><td class="font-semibold">Masse salariale</td><td class="text-white-dark">Total des salaires versés ce mois</td></tr>
                        <tr><td class="font-semibold">Flux de trésorerie</td><td class="text-white-dark">Solde global crédits / débits</td></tr>
                        <tr><td class="font-semibold">Employés</td><td class="text-white-dark">Nombre total d'employés actifs</td></tr>
                    </tbody>
                </table>
            </div>

            <h4 class="font-bold text-sm mb-3">Graphiques disponibles</h4>
            <ul class="space-y-2 text-sm text-white-dark">
                <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 7.757 8.586 6.343 10z"/></svg><span><strong class="text-black dark:text-white">Tendance des revenus (6 mois)</strong> — courbe d'évolution du CA</span></li>
                <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 7.757 8.586 6.343 10z"/></svg><span><strong class="text-black dark:text-white">Ventes journalières</strong> — graphique en barres jour par jour</span></li>
                <li class="flex items-start gap-2"><svg class="w-4 h-4 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 7.757 8.586 6.343 10z"/></svg><span><strong class="text-black dark:text-white">Top 5 des produits</strong> — les produits les plus vendus</span></li>
            </ul>

            <div class="mt-4 flex items-center gap-2 p-3 rounded-md bg-primary/10 border border-primary/20 text-sm text-primary">
