{% extends 'components/layout/default.html.twig' %}
{% block content %}

{# ===== HEADER ===== #}
<div class="flex items-start justify-between mb-6">
    <div class="flex items-center gap-4">
        {% if produit.image %}
            <img src="{{ asset('uploads/produits/' ~ produit.image) }}"
                 alt="{{ produit.designation }}"
                 class="h-20 w-20 object-cover rounded-lg border shadow-sm">
        {% else %}
            <div class="h-20 w-20 rounded-lg border bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
        {% endif %}
        <div>
            <div class="flex items-center gap-3 mb-1">
                <span class="text-gray-400 font-mono text-sm">{{ produit.code }}</span>
                {% if produit.categorie %}
                    <span class="badge bg-info">{{ produit.categorie.designation }}</span>
                {% endif %}
            </div>
            <h1 class="text-2xl font-bold">{{ produit.designation }}</h1>
        </div>
    </div>
    <div class="flex gap-2">
        <a href="{{ path('app_produits_index') }}" class="btn btn-outline-secondary btn-sm">← Retour</a>
        <a href="{{ path('app_produits_edit', {'id': produit.id}) }}" class="btn btn-primary btn-sm">Éditer</a>
        <form method="post" action="{{ path('app_produits_delete', {'id': produit.id}) }}"
              onsubmit="return confirm('Supprimer ce produit ?');" class="inline">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.id) }}">
            <button class="btn btn-danger btn-sm">Supprimer</button>
        </form>
    </div>
</div>

{# ===== KPI STOCK ===== #}
{% if stock %}
    {% set balance = stock.totalEntree - stock.totalSortie - stock.totalReserve %}
    {% set seuil   = stock.minimum * 1.1 %}
    {% if balance > seuil %}
        {% set stockClass = 'from-emerald-500 to-emerald-600' %}
        {% set stockLabel = 'OK' %}
    {% elseif balance > stock.minimum %}
        {% set stockClass = 'from-orange-400 to-orange-500' %}
        {% set stockLabel = 'Bas' %}
    {% else %}
        {% set stockClass = 'from-red-500 to-red-600' %}
        {% set stockLabel = 'Critique' %}
    {% endif %}
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">

    <div class="panel bg-gradient-to-r {{ stockClass }} text-white">
        <div class="text-xs font-semibold uppercase opacity-80 mb-1">Stock disponible</div>
        <div class="text-3xl font-bold">{{ balance }}</div>
        <div class="text-xs opacity-70 mt-1">{{ produit.uniteMesure }} — {{ stockLabel }}</div>
    </div>

    <div class="panel bg-gradient-to-r from-blue-500 to-blue-600 text-white">
        <div class="text-xs font-semibold uppercase opacity-80 mb-1">Entrées totales</div>
        <div class="text-3xl font-bold">{{ stock.totalEntree }}</div>
        <div class="text-xs opacity-70 mt-1">{{ produit.uniteMesure }} approvisionnés</div>
    </div>

    <div class="panel bg-gradient-to-r from-violet-500 to-violet-600 text-white">
        <div class="text-xs font-semibold uppercase opacity-80 mb-1">Sorties totales</div>
        <div class="text-3xl font-bold">{{ stock.totalSortie }}</div>
        <div class="text-xs opacity-70 mt-1">{{ produit.uniteMesure }} vendus</div>
    </div>

    <div class="panel bg-gradient-to-r from-amber-500 to-amber-600 text-white">
        <div class="text-xs font-semibold uppercase opacity-80 mb-1">Réservé</div>
        <div class="text-3xl font-bold">{{ stock.totalReserve }}</div>
        <div class="text-xs opacity-70 mt-1">{{ produit.uniteMesure }} en cours</div>
    </div>

</div>
{% endif %}

{# ===== INFOS + HISTORIQUE ===== #}
<div class="grid xl:grid-cols-3 gap-4">

    {# Infos produit #}
    <div class="panel">
        <h5 class="font-semibold text-lg mb-4">Informations</h5>
        <dl class="space-y-3 text-sm">
            <div class="flex justify-between border-b pb-2">
                <dt class="text-gray-500">Code</dt>
                <dd class="font-mono font-medium">{{ produit.code ?? '—' }}</dd>
            </div>
            <div class="flex justify-between border-b pb-2">
                <dt class="text-gray-500">Catégorie</dt>
                <dd>{{ produit.categorie ? produit.categorie.designation : '—' }}</dd>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
            <div class="flex justify-between border-b pb-2">
                <dt class="text-gray-500">Prix d'achat</dt>
                <dd class="font-semibold">Fc {{ produit.prixAchat ? produit.prixAchat|number_format(2) : '—' }}</dd>
            </div>
            {% endif %}
            <div class="flex justify-between border-b pb-2">
                <dt class="text-gray-500">Prix de vente</dt>
                <dd class="font-semibold">Fc {{ produit.prix|number_format(2) }}</dd>
            </div>
            <div class="flex justify-between border-b pb-2">
                <dt class="text-gray-500">Unité de mesure</dt>
                <dd>{{ produit.uniteMesure ?? '—' }}</dd>
            </div>
            <div class="flex justify-between border-b pb-2">
                <dt class="text-gray-500">Stock minimum</dt>
                <dd>{{ produit.minimum ?? '—' }}</dd>
            </div>
            <div class="flex justify-between border-b pb-2">
                <dt class="text-gray-500">Stock maximum</dt>
                <dd>{{ produit.maximum ?? '—' }}</dd>
            </div>
            <div class="flex justify-between border-b pb-2">
                <dt class="text-gray-500">Fabricant</dt>
                <dd>{{ produit.fabricant ?? '—' }}</dd>
            </div>
            <div class="flex justify-between">
                <dt class="text-gray-500">Date de péremption</dt>
                <dd>{{ produit.preemption ? produit.preemption|date('d/m/Y') : '—' }}</dd>
            </div>
        </dl>
    </div>

    {# Dernières entrées — admin uniquement (prix d'achat) #}
    {% if is_granted('ROLE_ADMIN') %}
    <div class="panel">
        <div class="flex justify-between items-center mb-4">
            <h5 class="font-semibold text-lg">Dernières entrées</h5>
            <a href="{{ path('app_approvisionnement_index') }}" class="text-primary text-sm hover:underline">Voir tout</a>
        </div>
        {% if dernieresEntrees %}
        <table class="table text-sm">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Qté</th>
                    <th>Coût (Fc)</th>
                    <th>Par</th>
                </tr>
            </thead>
            <tbody>
            {% for entree in dernieresEntrees %}
                <tr>
                    <td>{{ entree.createdAt ? entree.createdAt|date('d/m/Y') : '—' }}</td>
                    <td class="font-medium">{{ entree.qty }}</td>
                    <td>{{ entree.cout ? entree.cout|number_format(0, ',', ' ') : '—' }}</td>
                    <td>{{ entree.createdBy ?? '—' }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% else %}
            <p class="text-gray-400 text-sm">Aucun approvisionnement enregistré.</p>
        {% endif %}
    </div>
    {% endif %}{# end ROLE_ADMIN #}

    {# Dernières sorties #}
    <div class="panel">
        <div class="flex justify-between items-center mb-4">
            <h5 class="font-semibold text-lg">Dernières sorties</h5>
            <a href="{{ path('app_vente_index') }}" class="text-primary text-sm hover:underline">Voir tout</a>
        </div>
        {% if dernieresSorties %}
        <table class="table text-sm">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Qté</th>
                    <th>Prix unit.</th>
                    <th>Vente</th>
                </tr>
            </thead>
            <tbody>
            {% for sortie in dernieresSorties %}
                <tr>
                    <td>{{ sortie.createdAt ? sortie.createdAt|date('d/m/Y') : '—' }}</td>
                    <td class="font-medium">{{ sortie.qty }}</td>
                    <td>{{ sortie.prixUnitaire ? sortie.prixUnitaire|number_format(0, ',', ' ') : '—' }}</td>
                    <td>
                        {% if sortie.vente %}
                            <a href="{{ path('app_vente_show', {'id': sortie.vente.id}) }}"
                               class="text-primary hover:underline">
                                {{ sortie.vente.numeroVente ?? '#'~sortie.vente.id }}
                            </a>
                        {% else %}
                            —
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% else %}
            <p class="text-gray-400 text-sm">Aucune vente enregistrée.</p>
        {% endif %}
    </div>

</div>

{% endblock %}
