                            <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path opacity="0.5" d="M4 7L12 3L20 7V17L12 21L4 17V7Z" fill="currentColor"/>
                                <path d="M4 7L12 11M12 11L20 7M12 11V21M4 7L12 3L20 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Produits
                        </div>
                        <svg class="w-3.5 h-3.5 shrink-0 transition-transform duration-200" :class="{ 'rotate-90': openDropdowns['produit'] }" viewBox="0 0 24 24" fill="none">
