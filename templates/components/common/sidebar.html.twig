                    <button type="button"
                        class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-150 text-gray-600 dark:text-gray-400 hover:bg-primary/10 hover:text-primary dark:hover:text-primary"
                        :class="{ 'bg-primary/10 !text-primary': openDropdowns['categorie'] }"
                        @click="toggle('categorie')">
                        <div class="flex items-center gap-3">
                            <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path opacity="0.5" d="M3 5C3 3.895 3.895 3 5 3H9L11 7H5C3.895 7 3 6.105 3 5ZM3 5V19C3 20.105 3.895 21 5 21H19C20.105 21 21 20.105 21 19V9C21 7.895 20.105 7 19 7H11L9 3H5C3.895 3 3 3.895 3 5Z" fill="currentColor"/>
                                <path d="M3 5C3 3.895 3.895 3 5 3H9L11 7H19C20.105 7 21 7.895 21 9V19C21 20.105 20.105 21 19 21H5C3.895 21 3 20.105 3 19V5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                            </svg>
