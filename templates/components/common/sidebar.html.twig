                    </button>
                    <ul x-cloak x-show="openDropdowns['employe']" x-collapse data-menu="employe" class="mt-1 ml-4 pl-3 border-l-2 border-gray-100 dark:border-[#1b2e4b] space-y-0.5">
                        <li><a href="{{ path('app_employe_index') }}" class="block px-3 py-2 rounded-lg text-sm text-gray-500 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-colors">Liste des employés</a></li>
                        <li><a href="{{ path('app_employe_new') }}" class="block px-3 py-2 rounded-lg text-sm text-gray-500 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-colors">Nouvel employé</a></li>
                        <li><a href="{{ path('app_paie_index') }}" class="block px-3 py-2 rounded-lg text-sm text-gray-500 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-colors">Gestion de la paie</a></li>
                    </ul>
                </li>

                {# ─── ADMINISTRATION ─── #}
                <li class="px-2 pb-1.5 pt-5">
                    <span class="text-[10px] font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-600">Administration</span>
                </li>

                {# Utilisateurs #}
                <li>
                    <button type="button"
                        class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-150 text-gray-600 dark:text-gray-400 hover:bg-primary/10 hover:text-primary dark:hover:text-primary"
                        :class="{ 'bg-primary/10 !text-primary': openDropdowns['user'] }"
                        @click="toggle('user')">
                        <div class="flex items-center gap-3">
                            <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <circle opacity="0.5" cx="12" cy="7" r="4" fill="currentColor"/>
                                <path opacity="0.5" d="M4 21C4 17.134 7.582 14 12 14C16.418 14 20 17.134 20 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/>
                            </svg>
                            Utilisateurs
                        </div>
                        <svg class="w-3.5 h-3.5 shrink-0 transition-transform duration-200" :class="{ 'rotate-90': openDropdowns['user'] }" viewBox="0 0 24 24" fill="none">
                            <path d="M9 5L15 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <ul x-cloak x-show="openDropdowns['user']" x-collapse data-menu="user" class="mt-1 ml-4 pl-3 border-l-2 border-gray-100 dark:border-[#1b2e4b] space-y-0.5">
                        <li><a href="{{ path('app_user_index') }}" class="block px-3 py-2 rounded-lg text-sm text-gray-500 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-colors">Liste des utilisateurs</a></li>
                        <li><a href="{{ path('app_user_new') }}" class="block px-3 py-2 rounded-lg text-sm text-gray-500 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-colors">Nouvel utilisateur</a></li>
                    </ul>
                </li>

                {# Config alertes #}
                <li>
                    <a href="{{ path('app_alerte_config') }}"
                        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-all duration-150">
                        <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none">
                            <path opacity="0.5" d="M20.1 9.2214C18.29 9.2214 17.55 7.9414 18.45 6.3714C18.97 5.4614 18.66 4.3014 17.75 3.7814L16.02 2.7914C15.23 2.3214 14.21 2.6014 13.74 3.3914L13.63 3.5814C12.73 5.1514 11.25 5.1514 10.34 3.5814L10.23 3.3914C9.78 2.6014 8.76 2.3214 7.97 2.7914L6.24 3.7814C5.33 4.3014 5.02 5.4714 5.54 6.3814C6.45 7.9414 5.71 9.2214 3.9 9.2214C2.86 9.2214 2 10.0714 2 11.1214V12.8814C2 13.9214 2.85 14.7814 3.9 14.7814C5.71 14.7814 6.45 16.0614 5.54 17.6314C5.02 18.5414 5.33 19.7014 6.24 20.2214L7.97 21.2114C8.76 21.6814 9.78 21.4014 10.25 20.6114L10.36 20.4214C11.26 18.8514 12.74 18.8514 13.65 20.4214L13.76 20.6114C14.23 21.4014 15.25 21.6814 16.04 21.2114L17.77 20.2214C18.68 19.7014 18.99 18.5314 18.47 17.6314C17.56 16.0614 18.3 14.7814 20.11 14.7814C21.15 14.7814 22.01 13.9314 22.01 12.8814V11.1214C22 10.0814 21.15 9.2214 20.1 9.2214Z" fill="currentColor"/>
                            <path d="M12 15.25C13.7949 15.25 15.25 13.7949 15.25 12C15.25 10.2051 13.7949 8.75 12 8.75C10.2051 8.75 8.75 10.2051 8.75 12C8.75 13.7949 10.2051 15.25 12 15.25Z" fill="currentColor"/>
                        </svg>
                        Config. alertes
                    </a>
                </li>

                {# Journal d'audit — pharmacien et admin #}
                {% if is_granted('ROLE_PHARMACIEN') %}
                <li>
                    <a href="{{ path('app_audit_log_index') }}"
                        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-all duration-150">
                        <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none">
                            <path opacity="0.5" d="M3 10C3 6.22876 3 4.34315 4.17157 3.17157C5.34315 2 7.22876 2 11 2H13C16.7712 2 18.6569 2 19.8284 3.17157C21 4.34315 21 6.22876 21 10V14C21 17.7712 21 19.6569 19.8284 20.8284C18.6569 22 16.7712 22 13 22H11C7.22876 22 5.34315 22 4.17157 20.8284C3 19.6569 3 17.7712 3 14V10Z" fill="currentColor"/>
                            <path d="M8 10H16M8 14H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M8 6H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        Journal d'audit
                    </a>
                </li>
                {% endif %}

                {% endif %}

                {# Documentation — accessible à tous #}
                <li class="px-2 pb-1.5 pt-5">
                    <span class="text-[10px] font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-600">Aide</span>
                </li>
                <li>
                    <a href="{{ path('app_documentation') }}"
                        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-all duration-150">
                        <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none">
                            <path opacity="0.5" d="M3 10C3 6.22876 3 4.34315 4.17157 3.17157C5.34315 2 7.22876 2 11 2H13C16.7712 2 18.6569 2 19.8284 3.17157C21 4.34315 21 6.22876 21 10V14C21 17.7712 21 19.6569 19.8284 20.8284C18.6569 22 16.7712 22 13 22H11C7.22876 22 5.34315 22 4.17157 20.8284C3 19.6569 3 17.7712 3 14V10Z" fill="currentColor"/>
                            <path d="M8 12H16M8 8H16M8 16H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        Documentation
                    </a>
                </li>

                {# Spacer #}
                <li class="py-2"></li>

            </ul>

            {# ── Footer utilisateur ── #}
            <div class="shrink-0 border-t border-gray-100 dark:border-[#1b2e4b] p-3">
                <div class="flex items-center gap-3 px-2 py-2 rounded-lg">
                    <div class="w-8 h-8 rounded-full bg-primary/15 flex items-center justify-center shrink-0">
                        <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none">
                            <circle opacity="0.5" cx="12" cy="7" r="4" fill="currentColor"/>
                            <path d="M4 21C4 17.134 7.582 14 12 14C16.418 14 20 17.134 20 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-gray-800 dark:text-white truncate">
                            {{ app.user ? app.user.userIdentifier : 'Utilisateur' }}
                        </p>
                        <p class="text-xs text-gray-400 truncate">
                            {{ is_granted('ROLE_ADMIN') ? 'Administrateur' : 'Utilisateur' }}
                        </p>
                    </div>
                    <a href="{{ path('app_logout') }}"
                        title="Déconnexion"
                        class="w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:bg-red-50 dark:hover:bg-red-900/20 hover:text-red-500 transition-colors shrink-0">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="M15 12H2M2 12L5 9M2 12L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path opacity="0.5" d="M9.00195 7C9.01406 4.82497 9.10625 3.64706 9.87868 2.87463C10.7574 1.99596 12.1716 1.99596 15.0001 1.99596L16.0001 1.99596C18.8286 1.99596 20.2429 1.99596 21.1215 2.87463C22.0001 3.75331 22.0001 5.16752 22.0001 7.99596L22.0001 16.004C22.0001 18.8325 22.0001 20.2467 21.1215 21.1254C20.2429 22.004 18.8286 22.004 16.0001 22.004H15.0001C12.1716 22.004 10.7574 22.004 9.87868 21.1254C9.10625 20.3529 9.01406 19.175 9.00195 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                    </a>
                </div>
            </div>

        </div>
    </nav>
</div>

<script>
    document.addEventListener("alpine:init", () => {
        Alpine.data("sidebar", () => ({
            openDropdowns: {},

            toggle(key) {
                this.openDropdowns[key] = !this.openDropdowns[key];
            },

            init() {
                const currentPath = window.location.pathname;
                const link = document.querySelector('.sidebar a[href="' + currentPath + '"]');
                if (!link) return;

                link.classList.add('!text-primary', 'bg-primary/10', 'font-semibold');

                const subUl = link.closest('ul[data-menu]');
                if (subUl) {
                    const menuKey = subUl.dataset.menu;
                    if (menuKey) {
                        this.openDropdowns[menuKey] = true;
                    }
                }
            },
        }));
    });
</script>
