                            Dashboard
                        </div>
                        <svg class="w-3.5 h-3.5 shrink-0 transition-transform duration-200" :class="{ 'rotate-90': openDropdowns['dashboard'] }" viewBox="0 0 24 24" fill="none">
                            <path d="M9 5L15 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <ul x-cloak x-show="openDropdowns['dashboard']" x-collapse data-menu="dashboard" class="mt-1 ml-4 pl-3 border-l-2 border-gray-100 dark:border-[#1b2e4b] space-y-0.5">
