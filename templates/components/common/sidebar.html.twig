                        </svg>
                    </button>
                    <ul x-cloak x-show="openDropdowns['produit']" x-collapse data-menu="produit" class="mt-1 ml-4 pl-3 border-l-2 border-gray-100 dark:border-[#1b2e4b] space-y-0.5">
