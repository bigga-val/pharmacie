                        <li><a href="{{ path('app_approvisionnement_import') }}" class="block px-3 py-2 rounded-lg text-sm text-gray-500 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-colors">Importer</a></li>
                        <li><a href="{{ path('app_approvisionnement_index') }}" class="block px-3 py-2 rounded-lg text-sm text-gray-500 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-colors">Historique</a></li>
