                </li>

                {# Alertes #}
                <li>
                    <a href="{{ path('app_alerte_index') }}"
                        class="flex items-center justify-between px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-all duration-150">
                        <div class="flex items-center gap-3">
                            <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path d="M19.0001 9.7041V9C19.0001 5.13401 15.8661 2 12.0001 2C8.13407 2 5.00006 5.13401 5.00006 9V9.7041C5.00006 10.5491 4.74995 11.3752 4.28123 12.0783L3.13263 13.8012C2.08349 15.3749 2.88442 17.5139 4.70913 18.0116C9.48258 19.3134 14.5175 19.3134 19.291 18.0116C21.1157 17.5139 21.9166 15.3749 20.8675 13.8012L19.7189 12.0783C19.2502 11.3752 19.0001 10.5491 19.0001 9.7041Z" stroke="currentColor" stroke-width="1.5"/>
                                <path d="M7.5 19C8.15503 20.7478 9.92246 22 12 22C14.0775 22 15.845 20.7478 16.5 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            Alertes
                        </div>
                        {% if alertes.total > 0 %}
                        <span class="inline-flex items-center justify-center min-w-[20px] h-5 px-1.5 text-[10px] font-bold bg-danger text-white rounded-full">{{ alertes.total }}</span>
                        {% endif %}
                    </a>
                </li>

                {# ─── VENTES ─── #}
                <li class="px-2 pb-1.5 pt-5">
                    <span class="text-[10px] font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-600">Ventes</span>
                </li>

                {# CTA Nouvelle vente #}
                <li>
                    <a href="{{ path('app_vente_new') }}"
                        class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-semibold bg-primary text-white hover:bg-primary/90 active:scale-[0.98] transition-all duration-150 shadow-sm shadow-primary/30">
                        <svg class="shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                        </svg>
                        Nouvelle vente
                    </a>
                </li>

                {# Ventes #}
                <li>
                    <button type="button"
                        class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-150 text-gray-600 dark:text-gray-400 hover:bg-primary/10 hover:text-primary dark:hover:text-primary"
                        :class="{ 'bg-primary/10 !text-primary': openDropdowns['vente'] }"
                        @click="toggle('vente')">
                        <div class="flex items-center gap-3">
                            <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path opacity="0.5" d="M2 3H3.5L4.5 8M4.5 8H21L19 15H6L4.5 8Z" fill="currentColor"/>
                                <circle cx="9" cy="19" r="1.5" fill="currentColor"/>
                                <circle cx="17" cy="19" r="1.5" fill="currentColor"/>
                                <path d="M2 3H3.74L4.5 8M4.5 8H21L19 15H6L4.5 8Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
