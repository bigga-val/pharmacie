                {# ─── GÉNÉRAL ─── #}
                <li class="px-2 pb-1.5 pt-1">
                    <span class="text-[10px] font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-600">Général</span>
                </li>

                {# Dashboard #}
                <li>
                    <button type="button"
                        class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-150 group text-gray-600 dark:text-gray-400 hover:bg-primary/10 hover:text-primary dark:hover:text-primary"
                        :class="{ 'bg-primary/10 !text-primary': openDropdowns['dashboard'] }"
                        @click="toggle('dashboard')">
                        <div class="flex items-center gap-3">
                            <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none">
                                <path opacity="0.5" d="M2 12.2039C2 9.91549 2 8.77128 2.5192 7.82274C3.0384 6.87421 3.98695 6.28551 5.88403 5.10813L7.88403 3.86687C9.88939 2.62229 10.8921 2 12 2C13.1079 2 14.1106 2.62229 16.116 3.86687L18.116 5.10812C20.0131 6.28551 20.9616 6.87421 21.4808 7.82274C22 8.77128 22 9.91549 22 12.2039V13.725C22 17.6258 22 19.5763 20.8284 20.7881C19.6569 22 17.7712 22 14 22H10C6.22876 22 4.34315 22 3.17157 20.7881C2 19.5763 2 17.6258 2 13.725V12.2039Z" fill="currentColor"/>
