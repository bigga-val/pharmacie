                        <li><a href="{{ path('app_debit_new') }}" class="block px-3 py-2 rounded-lg text-sm text-gray-500 dark:text-gray-400 hover:bg-primary/10 hover:text-primary transition-colors">Nouvelle entrée</a></li>
