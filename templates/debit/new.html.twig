{% extends 'components/layout/default.html.twig' %}

{% block content %}
    <link rel="stylesheet" href="{{ asset('assets/css/datatables.min.css') }}">

    <div class="panel">
        <div class="flex justify-between mb-3">
            <h1>Nouvelle Entréee de Caisse</h1>
            {#            <a class="border border-2 p-2 m2 text-white rounded bg-primary" href="{{ path('app_debit_new') }}">Nouvelle Entréee</a>#}
            <h3>Taux: 1$ = {{ (app.session.get('tauxactif')) }} Fc</h3>

        </div>
        <div>
            <form action="" method="POST">
                <div>
                    <label for="devise">Devise</label>
                    <select class="form-input" name="devise" id="devise">
                        <option value="FC">FC</option>
                        <option value="USD">USD</option>
                    </select>
                </div>
                <div>
                    <label for="">Montant(Fc)</label>
                    <input type="number" id="montant" name="montant" inputmode="decimal" class="form-input">
                </div>
                <div>
                    <label for="raison">Raison</label>
                    {#                {{ form_widget(form.raison, {'attr': {'class': 'form-input'}}) }}#}
                    <textarea name="raison" id="raison" cols="30" class="form-input" rows="5"></textarea>
                </div>

                <br>
                <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
                {#    {{ include('debit/_form.html.twig') }}#}

            </form>

        </div>
    </div>
    <div class="panel mt-3">
        <div class="flex justify-between mb-3">
            <h1>5 dernières Entrées de Caisse</h1>

        </div>
        <br>
        <div>
            {#            <input type="text" class="form-input mb-3" id="myInput" placeholder="Rechercher..." title="Tapez ici pour rechercher">#}

            <table id="datatable" class="table">
                <thead>
                <tr>
                    <th>#</th>
                    <th>Date</th>
                    <th>Montant</th>
                    <th>Cree Par</th>
                    <th>Raison</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% set counter = 0 %}
                {% for debit in debits %}
                    {% set counter = counter + 1 %}
                    <tr>
                        <td>{{ counter }}</td>
                        <td>{{ debit.datedebit ? debit.createdAt|date('d-m-Y H:i:s') : '' }}</td>
                        <td>{{ debit.montant | number_format(0, ',', ' ') ~' '~ debit.devise }}</td>
                        <td>{{ debit.createdBy }}</td>
                        <td>{{ debit.raison }}</td>
                        <td>
{#                            <a href="{{ path('app_debit_show', {'id': debit.id}) }}">show</a>#}
                            <a class="btn btn-sm btn-primary" href="{{ path('app_devis_pdf', {'id': debit.id}) }}">Imprimer</a>
{#                            <a href="{{ path('app_debit_edit', {'id': debit.id}) }}">edit</a>#}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">no records found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

        </div>
    </div>
    <script src="{{ asset('assets/js/jquery.min.js') }}"></script>
    <script src="{{ asset('assets/js/datatables.js') }}"></script>


    <script>
        let table = new DataTable('#datatable', {
            order: [[1, 'desc']],
            language: {
                info: 'Page _PAGE_ / _PAGES_',
                infoEmpty: 'No records available',
                infoFiltered: '(filtered from _MAX_ total records)',
                lengthMenu: 'Afficher _MENU_ ligne par page',
                zeroRecords: 'Nothing found - sorry'
            },
            buttons: [
                'copy', 'excel', 'pdf'
            ]
        });
    </script>
{% endblock %}

