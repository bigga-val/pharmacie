{% extends 'components/layout/default.html.twig' %}

{% block content %}
<div class="panel">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-lg font-semibold text-gray-800 dark:text-white">
                Résultats de recherche
            </h2>
            <p class="text-sm text-gray-400 mt-0.5">
                {% if q|length >= 2 %}
                    {{ total }} résultat{{ total != 1 ? 's' : '' }} pour <strong class="text-gray-600 dark:text-gray-300">"{{ q }}"</strong>
                {% else %}
                    Saisissez au moins 2 caractères
                {% endif %}
            </p>
        </div>
        {# Barre de recherche inline pour relancer #}
        <form action="{{ path('app_search') }}" method="get" class="flex items-center gap-2">
            <div class="relative">
                <input type="text" name="q" value="{{ q }}"
                    id="searchInput"
                    class="form-input w-64 text-sm pr-8"
                    placeholder="Rechercher…"
                    autofocus>
                {% if q %}
                <a href="{{ path('app_search') }}"
                   title="Effacer la recherche"
                   class="absolute inset-y-0 right-2 flex items-center text-gray-300 hover:text-gray-500 transition-colors">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <circle opacity="0.5" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M14.5 9.5L9.5 14.5M9.5 9.5L14.5 14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </a>
                {% endif %}
            </div>
            <button type="submit" class="btn btn-primary btn-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <circle cx="11.5" cy="11.5" r="9.5" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
                    <path d="M18.5 18.5L22 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </button>
        </form>
    </div>
</div>

{% if q|length >= 2 and total == 0 %}
<div class="panel mt-4 py-14 text-center">
    <svg class="mx-auto mb-3 w-12 h-12 text-gray-300" viewBox="0 0 24 24" fill="none">
        <circle cx="11.5" cy="11.5" r="9.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M18.5 18.5L22 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <p class="text-gray-400 font-medium">Aucun résultat pour "{{ q }}"</p>
    <p class="text-gray-300 text-sm mt-1">Essayez avec un autre mot-clé</p>
</div>
{% endif %}

<div class="mt-4 space-y-4">

    {# ── Produits ── #}
    {% if produits is not empty %}
    <div class="panel">
        <div class="flex items-center gap-2 mb-4">
            <div class="w-7 h-7 rounded-lg bg-primary/10 flex items-center justify-center">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-primary">
                    <path opacity="0.5" d="M4 7L12 3L20 7V17L12 21L4 17V7Z" fill="currentColor"/>
                    <path d="M4 7L12 11M12 11L20 7M12 11V21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </div>
            <h3 class="font-semibold text-gray-700 dark:text-gray-200 text-sm uppercase tracking-wide">
                Produits <span class="text-gray-400 font-normal normal-case">({{ produits|length }})</span>
            </h3>
        </div>
        <div class="divide-y divide-gray-50 dark:divide-[#1b2e4b]">
            {% for produit in produits %}
            <a href="{{ path('app_produits_edit', {'id': produit.id}) }}"
               class="flex items-center justify-between py-3 px-2 rounded-lg hover:bg-primary/5 transition-colors group">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-[#1b2e4b] flex items-center justify-center shrink-0">
                        {% if produit.image %}
                            <img src="{{ asset('uploads/' ~ produit.image) }}" class="w-8 h-8 rounded-lg object-cover" alt="">
                        {% else %}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-gray-400">
                                <path opacity="0.5" d="M4 7L12 3L20 7V17L12 21L4 17V7Z" fill="currentColor"/>
                            </svg>
                        {% endif %}
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-800 dark:text-white group-hover:text-primary transition-colors">
                            {{ produit.designation }}
                        </p>
                        <p class="text-xs text-gray-400">
                            {% if produit.code %}Code : {{ produit.code }}{% endif %}
                            {% if produit.fabricant %} · {{ produit.fabricant }}{% endif %}
                        </p>
                    </div>
                </div>
                <div class="text-right shrink-0 ml-4">
                    <p class="text-sm font-semibold text-gray-700 dark:text-gray-300">{{ produit.prix ? produit.prix|number_format(2) : '—' }}</p>
                    {% if produit.categorie %}
                        <p class="text-xs text-gray-400">{{ produit.categorie }}</p>
                    {% endif %}
                </div>
            </a>
            {% endfor %}
        </div>
        <div class="mt-3 pt-3 border-t border-gray-50 dark:border-[#1b2e4b]">
            <a href="{{ path('app_produits_index') }}" class="text-xs text-primary hover:underline">Voir tous les produits →</a>
        </div>
    </div>
    {% endif %}

    {# ── Ventes / Factures ── #}
    {% if ventes is not empty %}
    <div class="panel">
        <div class="flex items-center gap-2 mb-4">
            <div class="w-7 h-7 rounded-lg bg-success/10 flex items-center justify-center">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-success">
                    <path opacity="0.5" d="M2 3H3.5L4.5 8M4.5 8H21L19 15H6L4.5 8Z" fill="currentColor"/>
                    <circle cx="9" cy="19" r="1.5" fill="currentColor"/>
                    <circle cx="17" cy="19" r="1.5" fill="currentColor"/>
                </svg>
            </div>
            <h3 class="font-semibold text-gray-700 dark:text-gray-200 text-sm uppercase tracking-wide">
                Factures <span class="text-gray-400 font-normal normal-case">({{ ventes|length }})</span>
            </h3>
        </div>
        <div class="divide-y divide-gray-50 dark:divide-[#1b2e4b]">
            {% for vente in ventes %}
            <a href="{{ path('app_vente_show', {'id': vente.id}) }}"
               class="flex items-center justify-between py-3 px-2 rounded-lg hover:bg-success/5 transition-colors group">
                <div class="flex items-center gap-3">
                    <span class="font-mono text-sm font-semibold text-gray-700 dark:text-gray-300 group-hover:text-success transition-colors">
                        {{ vente.numeroVente }}
                    </span>
                    <span class="text-xs text-gray-400">{{ vente.venteDate ? vente.venteDate|date('d/m/Y') : '' }}</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-xs text-gray-400">{{ vente.createdBy }}</span>
                    {% if vente.statusVente == 'paid' %}
                        <span class="badge bg-success/15 text-success text-xs px-2 py-0.5 rounded-full font-medium">Payée</span>
                    {% elseif vente.statusVente == 'progress' %}
                        <span class="badge bg-warning/15 text-warning text-xs px-2 py-0.5 rounded-full font-medium">En cours</span>
                    {% else %}
                        <span class="badge bg-danger/15 text-danger text-xs px-2 py-0.5 rounded-full font-medium">Annulée</span>
                    {% endif %}
                </div>
            </a>
            {% endfor %}
        </div>
        <div class="mt-3 pt-3 border-t border-gray-50 dark:border-[#1b2e4b]">
            <a href="{{ path('app_vente_index') }}" class="text-xs text-success hover:underline">Voir toutes les factures →</a>
        </div>
    </div>
    {% endif %}

    {# ── Employés ── #}
    {% if employes is not empty %}
    <div class="panel">
        <div class="flex items-center gap-2 mb-4">
            <div class="w-7 h-7 rounded-lg bg-info/10 flex items-center justify-center">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-info">
                    <circle opacity="0.5" cx="9" cy="6" r="4" fill="currentColor"/>
                    <ellipse opacity="0.5" cx="9" cy="17" rx="7" ry="4" fill="currentColor"/>
                </svg>
            </div>
            <h3 class="font-semibold text-gray-700 dark:text-gray-200 text-sm uppercase tracking-wide">
                Employés <span class="text-gray-400 font-normal normal-case">({{ employes|length }})</span>
            </h3>
        </div>
        <div class="divide-y divide-gray-50 dark:divide-[#1b2e4b]">
            {% for employe in employes %}
            <a href="{{ path('app_employe_payer', {'id': employe.id}) }}"
               class="flex items-center justify-between py-3 px-2 rounded-lg hover:bg-info/5 transition-colors group">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-info/15 flex items-center justify-center shrink-0">
                        <span class="text-xs font-bold text-info">{{ employe.nomcomplet|slice(0,1)|upper }}</span>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-800 dark:text-white group-hover:text-info transition-colors">
                            {{ employe.nomcomplet }}
                        </p>
                        <p class="text-xs text-gray-400">
                            {{ employe.matricule }}{% if employe.titre %} · {{ employe.titre }}{% endif %}
                        </p>
                    </div>
                </div>
                {% if employe.categorie %}
                <span class="badge bg-info/10 text-info text-xs px-2 py-0.5 rounded-full font-medium">{{ employe.categorie }}</span>
                {% endif %}
            </a>
            {% endfor %}
        </div>
        <div class="mt-3 pt-3 border-t border-gray-50 dark:border-[#1b2e4b]">
            <a href="{{ path('app_employe_index') }}" class="text-xs text-info hover:underline">Voir tous les employés →</a>
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
