{% extends 'components/layout/default.html.twig' %}

{% block content %}
<div class="space-y-6">

    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-semibold dark:text-white">Alertes</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_alerte_config') }}" class="btn btn-outline-primary btn-sm">
                <svg class="w-4 h-4 ltr:mr-1 rtl:ml-1 inline" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 15C13.6569 15 15 13.6569 15 12C15 10.3431 13.6569 9 12 9C10.3431 9 9 10.3431 9 12C9 13.6569 10.3431 15 12 15Z" stroke="currentColor" stroke-width="1.5"/>
                    <path opacity="0.5" d="M2 12C2 12 5 5 12 5C19 5 22 12 22 12C22 12 19 19 12 19C5 19 2 12 2 12Z" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                Configurer les alertes
            </a>
        {% endif %}
    </div>

    {% if alertes.total == 0 %}
        <div class="panel">
            <div class="flex flex-col items-center justify-center py-12 text-gray-400">
                <svg class="w-16 h-16 mb-4 text-success" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <p class="text-lg font-semibold text-success">Aucune alerte active</p>
                <p class="text-sm mt-1">Tous les stocks et péremptions sont dans les seuils configurés.</p>
            </div>
        </div>
    {% endif %}

    {# ── Alertes Stock Bas ── #}
    {% if alertes.config.actifStockBas %}
        <div class="panel">
            <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center gap-2 text-lg font-semibold dark:text-white">
                    <svg class="w-5 h-5 text-warning" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 7L12 3L20 7V17L12 21L4 17V7Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path opacity="0.5" d="M4 7L12 11M12 11L20 7M12 11V21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Stock bas
                </span>
                <span class="badge {{ alertes.stockBas|length > 0 ? 'badge-outline-danger' : 'badge-outline-success' }}">
                    {{ alertes.stockBas|length }} produit{{ alertes.stockBas|length != 1 ? 's' : '' }}
                </span>
            </div>

            {% if alertes.stockBas|length == 0 %}
                <p class="text-success text-sm">Tous les stocks sont au-dessus du seuil minimum.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table-hover">
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th>Code</th>
                                <th>Stock disponible</th>
                                <th>Minimum requis</th>
                                <th>Déficit</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in alertes.stockBas %}
                                {% set deficit = row.minimum - row.stockDisponible %}
                                <tr>
                                    <td>
                                        <a href="{{ path('app_produits_show', {id: row.produitID}) }}" class="text-primary hover:underline font-medium">
                                            {{ row.designation }}
                                        </a>
                                    </td>
                                    <td><span class="badge badge-outline-secondary">{{ row.code }}</span></td>
                                    <td>
                                        <span class="font-semibold {{ row.stockDisponible <= 0 ? 'text-danger' : 'text-warning' }}">
                                            {{ row.stockDisponible|number_format(0, ',', ' ') }}
                                        </span>
                                    </td>
                                    <td>{{ row.minimum|number_format(0, ',', ' ') }}</td>
                                    <td>
                                        <span class="badge badge-outline-danger">-{{ deficit|number_format(0, ',', ' ') }}</span>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    {% endif %}

    {# ── Alertes Péremption ── #}
    {% if alertes.config.actifPeremption %}
        <div class="panel">
            <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center gap-2 text-lg font-semibold dark:text-white">
                    <svg class="w-5 h-5 text-danger" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 6V12L16 14M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    Péremptions
                </span>
                <span class="badge {{ alertes.peremptions|length > 0 ? 'badge-outline-danger' : 'badge-outline-success' }}">
                    {{ alertes.peremptions|length }} produit{{ alertes.peremptions|length != 1 ? 's' : '' }}
                </span>
                <span class="text-xs text-gray-400">(alertes à {{ alertes.config.joursAvantPeremption }} jours ou moins)</span>
            </div>

            {% if alertes.peremptions|length == 0 %}
                <p class="text-success text-sm">Aucun produit n'expire dans les {{ alertes.config.joursAvantPeremption }} prochains jours.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table-hover">
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th>Code</th>
                                <th>Date de péremption</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in alertes.peremptions %}
                                <tr>
                                    <td>
                                        <a href="{{ path('app_produits_show', {id: item.produit.id}) }}" class="text-primary hover:underline font-medium">
                                            {{ item.produit.designation }}
                                        </a>
                                    </td>
                                    <td><span class="badge badge-outline-secondary">{{ item.produit.code }}</span></td>
                                    <td>{{ item.produit.preemption|date('d/m/Y') }}</td>
                                    <td>
                                        {% if item.expire %}
                                            <span class="badge badge-outline-danger">
                                                Expiré depuis {{ item.joursRestants|abs }} jour{{ item.joursRestants|abs != 1 ? 's' : '' }}
                                            </span>
                                        {% elseif item.joursRestants == 0 %}
                                            <span class="badge badge-outline-danger">Expire aujourd'hui</span>
                                        {% else %}
                                            <span class="badge badge-outline-warning">
                                                Dans {{ item.joursRestants }} jour{{ item.joursRestants != 1 ? 's' : '' }}
                                            </span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    {% endif %}

</div>
{% endblock %}
