{% extends 'components/layout/default.html.twig' %}

{% block content %}
<div class="max-w-xl">

    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('app_alerte_index') }}" class="text-gray-400 hover:text-primary">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15 19L8 12L15 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </a>
        <h1 class="text-2xl font-semibold dark:text-white">Configuration des alertes</h1>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success mb-4">{{ message }}</div>
    {% endfor %}

    <div class="panel">
        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

            {# ── Stock bas ── #}
            <div class="border-b dark:border-white/10 pb-6">
                <h2 class="text-base font-semibold dark:text-white mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-warning" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 7L12 3L20 7V17L12 21L4 17V7Z" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                    Alertes stock bas
                </h2>
                <div class="flex items-center gap-3">
                    {{ form_widget(form.actifStockBas, {'attr': {'class': 'w-10 h-6'}}) }}
                    <label class="text-sm dark:text-white-dark">{{ form_label(form.actifStockBas) }}</label>
                </div>
                {{ form_errors(form.actifStockBas) }}
                <p class="text-xs text-gray-400 mt-2">
                    Déclenche une alerte pour chaque produit dont le stock disponible est inférieur ou égal au seuil minimum défini sur le produit.
                </p>
            </div>

            {# ── Péremption ── #}
            <div>
                <h2 class="text-base font-semibold dark:text-white mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-danger" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 6V12L16 14M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    Alertes péremption
                </h2>
                <div class="flex items-center gap-3 mb-4">
                    {{ form_widget(form.actifPeremption, {'attr': {'class': 'w-10 h-6'}}) }}
                    <label class="text-sm dark:text-white-dark">{{ form_label(form.actifPeremption) }}</label>
                </div>
                {{ form_errors(form.actifPeremption) }}

                <div class="mt-4">
                    <label class="text-sm font-medium dark:text-white-dark block mb-1">
                        {{ form_label(form.joursAvantPeremption) }}
                    </label>
                    <div class="flex items-center gap-2">
                        {{ form_widget(form.joursAvantPeremption, {'attr': {'class': 'form-input w-28', 'min': 1, 'max': 365}}) }}
                        <span class="text-sm text-gray-400">jours</span>
                    </div>
                    {{ form_errors(form.joursAvantPeremption) }}
                    <p class="text-xs text-gray-400 mt-1">
                        Alerte déclenchée si un produit expire dans ce délai ou est déjà expiré.
                    </p>
                </div>
            </div>

            <div class="flex items-center gap-3 pt-2">
                <button type="submit" class="btn btn-primary">Enregistrer</button>
                <a href="{{ path('app_alerte_index') }}" class="btn btn-outline-danger">Annuler</a>
            </div>

        {{ form_end(form) }}
    </div>

</div>
{% endblock %}
