{% extends 'components/layout/default.html.twig' %}
{% block content %}

<div class="panel">
    <div class="flex justify-between mb-3">
        <h1 class="text-xl font-bold">Journal d'audit</h1>
        <span class="text-sm text-gray-500">{{ logs|length }} entrée(s)</span>
    </div>
</div>

{# Filtres #}
<div class="panel mb-4">
    <form method="GET" action="{{ path('app_audit_log_index') }}" class="flex flex-wrap gap-3 items-end">
        <div>
            <label class="block text-xs mb-1">Utilisateur</label>
            <input type="text" name="user" value="{{ filters.userEmail }}"
                   class="form-input w-44" placeholder="email...">
        </div>
        <div>
            <label class="block text-xs mb-1">Entité</label>
            <select name="entity" class="form-select w-44">
                <option value="">Toutes</option>
                {% for e in entities %}
                    <option value="{{ e }}" {% if filters.entityName == e %}selected{% endif %}>{{ e }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label class="block text-xs mb-1">Action</label>
            <select name="action" class="form-select w-36">
                <option value="">Toutes</option>
                <option value="CREATE" {% if filters.action == 'CREATE' %}selected{% endif %}>CREATE</option>
                <option value="UPDATE" {% if filters.action == 'UPDATE' %}selected{% endif %}>UPDATE</option>
                <option value="DELETE" {% if filters.action == 'DELETE' %}selected{% endif %}>DELETE</option>
            </select>
        </div>
        <div>
            <label class="block text-xs mb-1">Du</label>
            <input type="date" name="from" value="{{ filters.fromStr }}" class="form-input w-40">
        </div>
        <div>
            <label class="block text-xs mb-1">Au</label>
            <input type="date" name="to" value="{{ filters.toStr }}" class="form-input w-40">
        </div>
        <div class="flex gap-2">
            <button type="submit" class="btn btn-primary">Filtrer</button>
            <a href="{{ path('app_audit_log_index') }}" class="btn btn-outline-secondary">Réinitialiser</a>
        </div>
    </form>
</div>

{# Tableau #}
<div class="panel">
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Utilisateur</th>
                <th>Entité</th>
                <th>ID</th>
                <th>Action</th>
                <th>Modifications</th>
                <th>IP</th>
            </tr>
        </thead>
        <tbody>
        {% for log in logs %}
            <tr>
                <td class="whitespace-nowrap text-xs">{{ log.createdAt|date('d/m/Y H:i:s') }}</td>
                <td class="text-xs">{{ log.userEmail ?? '—' }}</td>
                <td><span class="badge bg-info">{{ log.entityName }}</span></td>
                <td class="text-center">{{ log.entityId ?? '—' }}</td>
                <td>
                    {% if log.action == 'CREATE' %}
                        <span class="badge bg-success">CREATE</span>
                    {% elseif log.action == 'UPDATE' %}
                        <span class="badge bg-warning">UPDATE</span>
                    {% else %}
                        <span class="badge bg-danger">DELETE</span>
                    {% endif %}
                </td>
                <td class="text-xs max-w-xs">
                    {% if log.action == 'UPDATE' and log.oldData %}
                        <details>
                            <summary class="cursor-pointer text-primary">Voir les changements</summary>
                            <div class="mt-1 space-y-1">
                            {% for field, oldVal in log.oldData %}
                                <div>
                                    <span class="font-semibold">{{ field }}</span> :
                                    <span class="text-danger line-through">{{ oldVal ?? 'null' }}</span>
                                    →
                                    <span class="text-success">{{ log.newData[field] ?? 'null' }}</span>
                                </div>
                            {% endfor %}
                            </div>
                        </details>
                    {% elseif log.action == 'CREATE' and log.newData %}
                        <details>
                            <summary class="cursor-pointer text-primary">Voir les données</summary>
                            <div class="mt-1">
                            {% for field, val in log.newData %}
                                <div><span class="font-semibold">{{ field }}</span> : {{ val ?? 'null' }}</div>
                            {% endfor %}
                            </div>
                        </details>
                    {% elseif log.action == 'DELETE' and log.oldData %}
                        <details>
                            <summary class="cursor-pointer text-danger">Voir les données supprimées</summary>
                            <div class="mt-1">
                            {% for field, val in log.oldData %}
                                <div><span class="font-semibold">{{ field }}</span> : {{ val ?? 'null' }}</div>
                            {% endfor %}
                            </div>
                        </details>
                    {% else %}
                        —
                    {% endif %}
                </td>
                <td class="text-xs">{{ log.ipAddress ?? '—' }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7" class="text-center">Aucun enregistrement</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
