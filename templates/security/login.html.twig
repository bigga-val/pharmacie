{% extends 'components/layout/auth.html.twig' %}

{% block title %}Insoft Afya | Connexion{% endblock %}

{% block content %}
<div class="min-h-screen bg-[#f0f4f8] dark:bg-[#060818] flex flex-col items-center justify-center p-4">

    {# ── Brand ── #}
    <div class="flex justify-center mb-8 select-none">
        <img src="{{ asset('assets/images/afya2.png') }}" alt="Insoft Afya" class="h-14 w-auto object-contain" />
    </div>

    {# ── Card ── #}
    <div class="w-full max-w-[400px] bg-white dark:bg-[#0e1726] rounded-2xl border border-gray-200/80 dark:border-[#1b2e4b] shadow-xl shadow-gray-200/60 dark:shadow-none overflow-hidden">

        {# Card header #}
        <div class="px-8 pt-7 pb-5 border-b border-gray-100 dark:border-[#1b2e4b]">
            <h2 class="text-base font-semibold text-gray-800 dark:text-white">Connexion</h2>
            <p class="text-[13px] text-gray-400 mt-0.5">Entrez vos identifiants pour accéder à votre espace</p>
        </div>

        {# Card body #}
        <div class="px-8 py-7">

            {% if error %}
                <div class="alert alert-danger mb-5 text-sm">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}
            {% if app.user %}
                <div class="mb-5 text-sm text-gray-500 dark:text-gray-400">
                    Connecté en tant que <strong>{{ app.user.userIdentifier }}</strong> —
                    <a class="text-danger hover:underline" href="{{ path('app_logout') }}">se déconnecter</a>
                </div>
            {% endif %}

            <form class="space-y-5" method="post">

                <div class="space-y-1.5">
                    <label for="inputEmail" class="block text-[13px] font-medium text-gray-600 dark:text-gray-300">
                        Nom d'utilisateur
                    </label>
                    <input
                        type="text"
                        value="{{ last_username }}"
                        name="username"
                        id="inputEmail"
                        class="form-input w-full text-sm"
                        autocomplete="username"
                        required
                        autofocus
                        placeholder="Entrez votre identifiant"
                    >
                </div>

                <div class="space-y-1.5">
                    <label for="inputPassword" class="block text-[13px] font-medium text-gray-600 dark:text-gray-300">
                        Mot de passe
                    </label>
                    <input
                        type="password"
                        name="password"
                        id="inputPassword"
                        class="form-input w-full text-sm"
                        autocomplete="current-password"
                        required
                        placeholder="••••••••"
                    >
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                </div>

                <button type="submit" class="btn btn-primary w-full !mt-6 font-medium">
                    Se connecter
                </button>

            </form>
        </div>
    </div>

    {# ── Footer ── #}
    <p class="mt-8 text-[12px] text-gray-400 dark:text-gray-600">
        &copy; {{ "now"|date("Y") }} Insoft Afya
    </p>

</div>
{% endblock %}
